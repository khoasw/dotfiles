#!/usr/bin/env bash
set -euo pipefail

readonly XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
readonly XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
readonly XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
readonly XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
readonly DOTDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

create_directories() {
    echo '> creating essential directories/files'
    mkdir -p "$XDG_DATA_HOME"
    mkdir -p "$XDG_CONFIG_HOME"
    mkdir -p "$XDG_STATE_HOME"
    mkdir -p "$XDG_CACHE_HOME"
    mkdir -p "$HOME/repos"
    mkdir -p "$HOME/personal"
}

is_linux_server() {
    [[ $(uname -s) != Linux ]] && return 1
    [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" && -z "${XDG_CURRENT_DESKTOP:-}" ]]
}

link_dotfiles() {
    echo '> linking dotfiles'

    if is_linux_server; then
        ln -sfn "$DOTDIR/.tmux.conf" "$HOME/.tmux.conf"
        ln -sfn "$DOTDIR/nvim/init.vim" "$HOME/.vimrc"
        ln -sfn "$DOTDIR/.psqlrc" "$HOME/.psqlrc"
        return 0
    fi

    local -a dotfiles=(ghostty fish nvim .tmux.conf .psqlrc .gitignore)
    for file in "${dotfiles[@]}"; do
        if [[ -d $DOTDIR/$file ]]; then
            ln -sfn "$DOTDIR/$file" "$XDG_CONFIG_HOME/$file"
        elif [[ -f $DOTDIR/$file ]]; then
            ln -sfn "$DOTDIR/$file" "$HOME/$file"
        else # print out missing file
            echo "! file not found: $DOTDIR/$file" >&2
        fi # probably will never happen; should not be
    done
}

setup_macos() {
    if ! xcode-select -p &>/dev/null; then
        echo '> installing command line tools for xcode'
        xcode-select --install
    fi

    if ! command -v brew &>/dev/null; then
        echo '> installing homebrew'
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi

    brew update
    local -a packages=(git fish watch tmux neovim tree ncdu ripgrep jq ghostty font-ubuntu-sans-mono)
    echo '> installing essential packages'
    brew install "${packages[@]}"
}

setup_linux() {
    sudo apt-get update && sudo apt-get upgrade -y
    if is_linux_server; then
        local -a packages=(curl git tmux)
        echo '> installing essential packages (no desktop environment)'
        sudo apt-get install -y "${packages[@]}"
        return 0
    fi

    local -a packages=(curl git fish watch tmux neovim tree ncdu ripgrep jq)
    echo '> installing essential packages'
    sudo apt-get install -y "${packages[@]}"
    sudo snap install ghostty --classic

    if command -v gsettings &> /dev/null; then
        echo '> disable dash to dock hot-keys on ubuntu'
        gsettings set org.gnome.shell.extensions.dash-to-dock hot-keys false
    fi # to switch workspace using Super+number instead of application
}

configure_git() {
    echo '> configuring git'
    git config --global diff.tool nvimdiff
    git config --global merge.tool nvimdiff
    git config --global mergetool.keepBackup false
    git config --global pull.rebase true
    git config --global core.excludesFile "$HOME/.gitignore"
}

configure_shell() {
    if [[ $SHELL == */fish ]]; then
        echo '* default shell is already fish'
        return 0
    fi

    echo '> changing default shell to fish'
    readonly fish_path=$(command -v fish)
    if [[ -z $fish_path ]]; then
        echo '! fish not found in path' >&2
        return 1
    fi

    if ! grep -q "^$fish_path$" /etc/shells; then
        echo "> adding $fish_path to /etc/shells"
        echo "$fish_path" | sudo tee -a /etc/shells
    fi

    chsh -s "$fish_path"
    echo '* please log out and log back in for shell change to take effect'
}

main() {
    if ! is_linux_server; then
        create_directories
    fi

    link_dotfiles

    if [[ $(uname -s) == Darwin ]]; then
        setup_macos
    else
        setup_linux
    fi

    if ! is_linux_server; then
        configure_git
        configure_shell
    fi
}

main "$@"
# vim: ft=bash
